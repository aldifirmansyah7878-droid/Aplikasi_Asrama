<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNamaPenghuni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Penghuni"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvKamar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kamar: 9"
            android:textSize="14sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tvPengirim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengirim: melvin"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvJenisPaket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sepatu"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-06-30"
            android:textSize="12sp"
            android:textColor="#999"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Menunggu"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_paket_menunggu" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnTerima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terima"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnTolak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tolak"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- ===== TAMBAHKAN btnSelesai ===== -->
            <Button
                android:id="@+id/btnSelesai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selesai"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail"
                android:backgroundTint="#1A237E"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>