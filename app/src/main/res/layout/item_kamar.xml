<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: Nomor Kamar + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNomorKamar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kamar 101"
                    android:textColor="#1A237E"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvLantai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lantai 1"
                    android:textColor="#757575"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Badge Status -->
            <TextView
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_hijau"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="Tersedia"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Garis pemisah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp"/>

        <!-- Kapasitas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Kapasitas"
                android:textColor="#9E9E9E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvKapasitas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/2 orang"
                android:textColor="#424242"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- Harga -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Harga/Bulan"
                android:textColor="#9E9E9E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvHarga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 500.000"
                android:textColor="#F57C00"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Fasilitas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Fasilitas"
                android:textColor="#9E9E9E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvFasilitas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AC, Kasur, Lemari"
                android:textColor="#424242"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- Tombol Edit & Hapus -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="Edit"
                android:textColor="#1A237E"
                app:strokeColor="#1A237E"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Hapus"
                android:textColor="#F44336"
                app:strokeColor="#F44336"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>