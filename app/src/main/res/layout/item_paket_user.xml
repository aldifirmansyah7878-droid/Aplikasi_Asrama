<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nama Pengirim -->
        <TextView
            android:id="@+id/tvNamaPengirim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pengirim"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A237E" />

        <!-- Jenis Paket -->
        <TextView
            android:id="@+id/tvJenisPaket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis: Paket"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginTop="4dp" />

        <!-- Tanggal Datang -->
        <TextView
            android:id="@+id/tvTanggalDatang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal: 2026-06-29"
            android:textSize="12sp"
            android:textColor="#999"
            android:layout_marginTop="4dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Menunggu"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_paket_menunggu" />

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A237E"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>