<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris Nama & Kamar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="1">

            <TextView
                android:id="@+id/tvNama"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:text="Nama"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvKamar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:text="Kamar: 9"
                android:textSize="13sp"
                android:textColor="#666"
                android:gravity="end" />
        </LinearLayout>

        <!-- Judul Keluhan -->
        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Judul Keluhan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <!-- Tanggal -->
        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-06-29"
            android:textSize="12sp"
            android:textColor="#999"
            android:layout_marginTop="2dp" />

        <!-- Status dengan ukuran lebih kecil -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="Menunggu"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_keluhan" />

        <!-- Tombol Aksi dengan ukuran seragam -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="3"
            android:gravity="center">

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Detail"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A237E"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:maxWidth="100dp" />

            <Button
                android:id="@+id/btnTanggapan"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Tanggapi"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:maxWidth="100dp" />

            <Button
                android:id="@+id/btnHapus"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Hapus"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:layout_marginStart="4dp"
                android:paddingHorizontal="0dp"
                android:minWidth="0dp"
                android:maxWidth="100dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>