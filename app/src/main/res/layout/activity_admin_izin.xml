<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F5F9">

    <!-- Toolbar dengan gradien elegan (biru gelap ke abu-abu kebiruan) -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar_elegant"
        app:titleTextColor="#FFFFFF"
        app:title="Daftar Izin"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Headline" />

    <!-- Konten utama -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Card info jumlah menunggu dengan aksen emas lembut -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FEF9E3"
            app:strokeColor="#FCD34D"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="⏳"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvJumlahMenunggu"
                    android:layout_width="0dp"
                    android:layout_weight="5"
                    android:layout_height="wrap_content"
                    android:text="Memuat..."
                    android:textColor="#B45309"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_warning"
                    app:tint="#F59E0B" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Label filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Status"
            android:textSize="13sp"
            android:textColor="#475569"
            android:letterSpacing="0.03"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Chip filter dengan desain elegant -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semua"
                    android:textColor="@drawable/chip_text_color"
                    app:chipBackgroundColor="@drawable/chip_bg_elegant"
                    app:chipStrokeColor="@drawable/chip_stroke_elegant"
                    app:chipStrokeWidth="0.5dp"
                    app:chipCornerRadius="28dp"
                    android:layout_marginEnd="10dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMenunggu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menunggu"
                    android:textColor="@drawable/chip_text_color"
                    app:chipBackgroundColor="@drawable/chip_bg_elegant"
                    app:chipStrokeColor="@drawable/chip_stroke_elegant"
                    app:chipStrokeWidth="0.5dp"
                    app:chipCornerRadius="28dp"
                    android:layout_marginEnd="10dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDisetujui"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disetujui"
                    android:textColor="@drawable/chip_text_color"
                    app:chipBackgroundColor="@drawable/chip_bg_elegant"
                    app:chipStrokeColor="@drawable/chip_stroke_elegant"
                    app:chipStrokeWidth="0.5dp"
                    app:chipCornerRadius="28dp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- RecyclerView dengan item card elegan (layout item akan diterapkan di adapter) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvIzin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>