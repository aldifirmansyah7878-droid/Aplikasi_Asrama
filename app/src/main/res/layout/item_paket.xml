<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivFotoPaket"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_paket_default"
            android:background="@drawable/bg_icon_light"
            android:padding="8dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNamaPenghuni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Penghuni"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />

            <TextView
                android:id="@+id/tvNomorKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kamar: 101"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvPengirim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengirim: Toko ABC"
                android:textSize="12sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/tvJenisPaket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis: Dokumen"
                android:textSize="12sp"
                android:textColor="#64748B" />

            <!-- 🟢 ADD THIS LINE for tvTanggal -->
            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tanggal: -"
                android:textSize="12sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Belum Diambil"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnAmbil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ambil"
            android:backgroundTint="#4F46E5"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>